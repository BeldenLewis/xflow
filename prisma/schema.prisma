generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships         WorkspaceMember[]
  utmLinks            UTMLink[]
  notifications       Notification[]
  sentInvitations     WorkspaceInvitation[] @relation("InvitedBy")
  receivedInvitations WorkspaceInvitation[] @relation("InvitedUser")
  activityLogs        ActivityLog[] @relation("ActivityActor")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        WorkspaceMember[]
  projects       Project[]
  utmLinks       UTMLink[]
  utmPresets     UTMPreset[]
  utmTemplates   UTMTemplate[]
  invitations    WorkspaceInvitation[]
  collectSources CollectSource[]
  collectRecords CollectRecord[]
  activityLogs   ActivityLog[]
  dashboardWidgets DashboardWidget[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  role        Role     @default(MEMBER)
  userId      String
  workspaceId String
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model WorkspaceInvitation {
  id            String   @id @default(cuid())
  workspaceId   String
  invitedUserId String
  invitedById   String
  role          Role     @default(MEMBER)
  status        String   @default("PENDING") // PENDING | ACCEPTED | DECLINED
  createdAt     DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedUser User      @relation("InvitedUser", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([workspaceId, invitedUserId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "WORKSPACE_INVITE" | "ROLE_CHANGED" | "MEMBER_REMOVED"
  data      Json
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  utmLinks         UTMLink[]
  collectSources   CollectSource[]
  collectRecords   CollectRecord[]
  dashboardWidgets DashboardWidget[]
}

model UTMPreset {
  id          String    @id @default(cuid())
  workspaceId String
  field       String    // "source" | "medium" | "term" | "content"
  value       String
  label       String?   // 기본 모드 드롭다운에 표시될 이름 (예: "구글" → value: "google")
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, field, value])
}

model UTMTemplate {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  source      String
  medium      String
  campaign    String?
  term        String?
  content     String?
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model CollectSource {
  id             String   @id @default(cuid())
  projectId      String
  workspaceId    String
  name           String
  description    String?
  apiKey         String   @unique @default(cuid())
  siteUrl        String?
  successTrigger String   @default("정상적으로 접수되었습니다")
  redirectUrl    String?
  isActive         Boolean  @default(true)
  discoveredFields Json?
  webhookUrl       String?
  notifyOnSubmit   Boolean  @default(false)
  allowedOrigins   String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fieldMappings FieldMapping[]
  records       CollectRecord[]
  activityLogs  ActivityLog[]
}

model FieldMapping {
  id         String   @id @default(cuid())
  sourceId   String
  index      Int
  key        String
  label      String
  type       String   @default("text") // text | select | checkbox | radio
  isRequired Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  source CollectSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, index])
  @@unique([sourceId, key])
}

model CollectRecord {
  id          String   @id @default(cuid())
  sourceId    String
  projectId   String
  workspaceId String
  data        Json
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  // first-touch attribution (최초 유입 시점의 UTM)
  firstUtmSource   String?
  firstUtmMedium   String?
  firstUtmCampaign String?
  firstUtmTerm     String?
  firstUtmContent  String?
  firstReferrer    String?
  firstSeenAt      DateTime?
  referrer    String?
  userAgent   String?
  ip          String?
  createdAt   DateTime @default(now())

  source    CollectSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([sourceId, createdAt(sort: Desc)])
}

model ActivityLog {
  id          String   @id @default(cuid())
  workspaceId String
  sourceId    String?
  userId      String?
  action      String   // "source.created" | "source.deleted" | "key.regenerated" | "record.deleted" | "record.updated" | "records.imported" | "records.cleaned" | "records.normalized" | "records.bulk_deleted"
  meta        Json?
  createdAt   DateTime @default(now())

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  source    CollectSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  user      User?          @relation("ActivityActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([sourceId, createdAt(sort: Desc)])
}

model DashboardWidget {
  id          String   @id @default(cuid())
  projectId   String
  workspaceId String
  type        String   // kpi | time_series | utm_breakdown | top_n | field_distribution | recent_feed
  title       String
  config      Json     // 위젯별 설정 (sourceId, field, metric, dimension, topN, granularity 등)
  position    Int      @default(0)
  width       String   @default("half") // full | half | third
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([projectId, position])
}

model UTMLink {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String?
  createdById String
  name        String?
  url         String
  utmSource   String
  utmMedium   String
  utmCampaign String
  utmTerm     String?
  utmContent  String?
  fullUrl     String
  shortUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
}
