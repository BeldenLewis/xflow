generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships         WorkspaceMember[]
  utmLinks            UTMLink[]
  shortLinks          ShortLink[]
  notifications       Notification[]
  sentInvitations     WorkspaceInvitation[] @relation("InvitedBy")
  receivedInvitations WorkspaceInvitation[] @relation("InvitedUser")
  activityLogs        ActivityLog[] @relation("ActivityActor")
  apiTokens           ApiToken[]
  notificationPrefs   NotificationPref[]
  projectMemberships  ProjectMember[]
}

model Workspace {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  members        WorkspaceMember[]
  projects       Project[]
  utmLinks       UTMLink[]
  shortLinks     ShortLink[]
  utmPresets     UTMPreset[]
  utmTemplates   UTMTemplate[]
  invitations    WorkspaceInvitation[]
  collectSources   CollectSource[]
  collectRecords   CollectRecord[]
  activityLogs     ActivityLog[]
  dashboardWidgets DashboardWidget[]
  dashboards       Dashboard[]
  scheduledReports ScheduledReport[]
  apiTokens        ApiToken[]
  webinars         Webinar[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  role        Role     @default(MEMBER)
  userId      String
  workspaceId String
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model WorkspaceInvitation {
  id            String   @id @default(cuid())
  workspaceId   String
  invitedUserId String?  // null 이면 미가입자 이메일 초대
  invitedEmail  String?  // 이메일 기반 초대 시 사용 (가입 시 매칭)
  invitedById   String
  role          Role     @default(MEMBER)
  status        String   @default("PENDING") // PENDING | ACCEPTED | DECLINED
  token         String?  @unique // 이메일 링크용 — null 이면 인앱 초대
  createdAt     DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedUser User?     @relation("InvitedUser", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([workspaceId, invitedUserId])
  @@index([invitedEmail, status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "WORKSPACE_INVITE" | "ROLE_CHANGED" | "MEMBER_REMOVED"
  data      Json
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  workspaceId String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  utmLinks         UTMLink[]
  collectSources   CollectSource[]
  collectRecords   CollectRecord[]
  dashboardWidgets DashboardWidget[]
  dashboards       Dashboard[]
  projectMembers   ProjectMember[]
  webinars         Webinar[]
}

model UTMPreset {
  id          String    @id @default(cuid())
  workspaceId String
  field       String    // "source" | "medium" | "campaign"
  value       String
  label       String?   // 기본 모드 드롭다운에 표시될 이름 (예: "구글" → value: "google")
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, field, value])
}

model UTMTemplate {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  source      String
  medium      String
  campaign    String?
  term        String?
  content     String?
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model CollectSource {
  id             String   @id @default(cuid())
  projectId      String
  workspaceId    String
  name           String
  description    String?
  apiKey         String   @unique @default(cuid())
  siteUrl        String?
  successTrigger String   @default("정상적으로 접수되었습니다")
  redirectUrl    String?
  isActive         Boolean   @default(true)
  discoveredFields Json?
  webhookUrl       String?
  notifyOnSubmit   Boolean   @default(false)
  allowedOrigins   String[]  @default([])
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fieldMappings FieldMapping[]
  records       CollectRecord[]
  activityLogs  ActivityLog[]
}

model FieldMapping {
  id         String   @id @default(cuid())
  sourceId   String
  index      Int
  key        String
  label      String
  type       String   @default("text") // text | select | checkbox | radio
  isRequired Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  source CollectSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, index])
  @@unique([sourceId, key])
}

model CollectRecord {
  id          String   @id @default(cuid())
  sourceId    String
  projectId   String
  workspaceId String
  data        Json
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  // first-touch attribution (최초 유입 시점의 UTM)
  firstUtmSource   String?
  firstUtmMedium   String?
  firstUtmCampaign String?
  firstUtmTerm     String?
  firstUtmContent  String?
  firstReferrer    String?
  firstSeenAt      DateTime?
  referrer    String?
  userAgent   String?
  ip          String?
  createdAt   DateTime @default(now())

  source    CollectSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([sourceId, createdAt(sort: Desc)])
}

model ActivityLog {
  id          String   @id @default(cuid())
  workspaceId String
  sourceId    String?
  userId      String?
  action      String   // "source.created" | "source.deleted" | "key.regenerated" | "record.deleted" | "record.updated" | "records.imported" | "records.cleaned" | "records.normalized" | "records.bulk_deleted"
  meta        Json?
  createdAt   DateTime @default(now())

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  source    CollectSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  user      User?          @relation("ActivityActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([sourceId, createdAt(sort: Desc)])
}

model Dashboard {
  id           String   @id @default(cuid())
  projectId    String
  workspaceId  String
  name         String
  description  String?
  sortOrder    Int      @default(0)
  isDefault    Boolean  @default(false)
  shareToken   String?  @unique
  shareEnabled Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  widgets          DashboardWidget[]
  scheduledReports ScheduledReport[]

  @@index([projectId, sortOrder])
}

model DashboardWidget {
  id          String   @id @default(cuid())
  dashboardId String?
  projectId   String
  workspaceId String
  type        String
  title       String
  config      Json
  position    Int      @default(0)
  width       String   @default("half")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dashboard Dashboard? @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([dashboardId, position])
  @@index([projectId, position])
}

model ScheduledReport {
  id          String   @id @default(cuid())
  dashboardId String
  workspaceId String
  name        String
  cron        String   // 예: "0 9 * * 1" (매주 월 9시)
  channel     String   // "slack" | "email"
  target      String   // slack webhook URL 또는 이메일 주소
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([nextRunAt])
  @@index([dashboardId])
}

// 데이터 자동 보관 정책 (GDPR/개인정보 자동 삭제)
// 소스 단위로 N일 지난 레코드 자동 제거
model CollectRetentionPolicy {
  sourceId   String   @id
  retainDays Int      // 0 = 영구 보관
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 워크스페이스 단위 API 토큰 (외부 도구 연동)
model ApiToken {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String    // 발급한 사용자
  name        String    // 사용자 지정 라벨 (예: "Zapier 연동")
  tokenHash   String    @unique // SHA-256 hash of token
  prefix      String    // 토큰 앞 8자 (식별용 — 평문 토큰은 발급 직후 한 번만 표시)
  scopes      String[]  @default([]) // ["records:read", "records:write", "dashboards:read"]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// 사용자 알림 환경설정 (어떤 이벤트의 인앱 알림을 받을지)
model NotificationPref {
  id        String   @id @default(cuid())
  userId    String
  eventType String   // "WORKSPACE_INVITE" | "COLLECT_SUBMITTED" | "REPORT_SENT" | "ROLE_CHANGED" 등
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType])
}

// 프로젝트 단위 권한 (워크스페이스 권한 위에 덮어쓰기)
// 없으면 워크스페이스 권한이 그대로 적용됨.
model ProjectMember {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  role      String   // "VIEWER" | "EDITOR" | "ADMIN"
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model UTMLink {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String?
  createdById String
  name        String?
  url         String
  utmSource   String
  utmMedium   String
  utmCampaign String
  utmTerm     String?
  utmContent  String?
  fullUrl     String
  shortUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model ShortLink {
  id          String   @id @default(cuid())
  code        String   @unique
  longUrl     String
  workspaceId String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([createdById, createdAt(sort: Desc)])
}

model Webinar {
  id             String   @id @default(cuid())
  workspaceId    String
  projectId      String
  name           String
  slug           String   @unique
  description    String?
  liveStartAt    DateTime
  liveEndAt      DateTime
  signupDeadline DateTime
  theme          Json     // { accentColor, bgColor, surfaceColor, textColor, font, borderRadius, bgEffect }
  config         Json     // { youtubeId, calendarUrl, surveyUrl, etc. }
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace     Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project       Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessions      WebinarSession[]
  registrations WebinarRegistration[]
  questions     WebinarQA[]
  announcements WebinarAnnouncement[]
  popups        WebinarPopup[]
  tallyPushes   WebinarTallyPush[]

  @@index([projectId, createdAt(sort: Desc)])
  @@index([workspaceId])
  @@index([slug])
}

model WebinarSession {
  id          String  @id @default(cuid())
  webinarId   String
  number      Int
  title       String
  speaker     String?
  description String?
  startTime   String
  endTime     String

  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@index([webinarId, number])
}

model WebinarRegistration {
  id             String    @id @default(cuid())
  webinarId      String
  name           String
  phone          String?
  email          String?
  company        String?
  department     String?
  jobTitle       String?
  industry       String?
  agreeMarketing Boolean   @default(false)
  agreePrivacy   Boolean   @default(true)
  memo           String?
  enteredAt      DateTime?
  leftAt         DateTime?
  lastPingAt     DateTime?
  presencePingAt DateTime?
  stayMinutes    Int       @default(0)
  isActive       Boolean   @default(false)
  submittedAt    DateTime  @default(now())

  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@index([webinarId, submittedAt(sort: Desc)])
  @@index([webinarId, phone])
  @@index([webinarId, email])
}

model WebinarQA {
  id             String   @id @default(cuid())
  webinarId      String
  registrationId String?
  question       String
  sessionNumber  Int?
  status         String   @default("pending")
  name           String?
  company        String?
  phone          String?
  email          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@index([webinarId, createdAt(sort: Desc)])
  @@index([webinarId, status])
}

model WebinarAnnouncement {
  id        String   @id @default(cuid())
  webinarId String
  type      String   @default("info")
  message   String
  isActive  Boolean  @default(false)
  sentBy    String?
  createdAt DateTime @default(now())

  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@index([webinarId, isActive])
}

model WebinarPopup {
  id                  String   @id @default(cuid())
  webinarId           String
  type                String   @default("notice")
  title               String
  message             String?
  buttonLabel         String?
  buttonUrl           String?
  secondaryLabel      String?
  secondaryUrl        String?
  integrationType     String   @default("link")
  embedCode           String?
  tallyFormId         String?
  tallyEmojiText      String?
  tallyEmojiAnimation String?
  tallyLayout         String?
  tallyWidth          Int?
  tallyAutoClose      Int?
  dismissible         Boolean  @default(true)
  isActive            Boolean  @default(false)
  sentBy              String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@index([webinarId, isActive])
}

model WebinarTallyPush {
  id                   String   @id @default(cuid())
  webinarId            String
  title                String
  formId               String
  emojiText            String?
  emojiAnimation       String?
  layout               String   @default("modal")
  width                Int      @default(700)
  autoClose            Int      @default(5000)
  showOnce             Boolean  @default(true)
  doNotShowAfterSubmit Boolean  @default(true)
  memo                 String?
  isActive             Boolean  @default(false)
  sentBy               String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@index([webinarId, isActive])
}
